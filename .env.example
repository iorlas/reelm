# ── Auth (Auth0 OAuth 2.1) ──
# AUTH0_DOMAIN=               # e.g. your-tenant.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=

# ── Jackett ──
JACKETT_URL=http://jackett:9117
# JACKETT_API_KEY=

# ── TMDB ──
# TMDB_API_KEY=               # Get from: https://www.themoviedb.org/settings/api

# ── Transmission ──
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_PATH=/transmission/rpc
TRANSMISSION_USER=
TRANSMISSION_PASS=
TRANSMISSION_SSL=false

# ── WebDAV (storage backend) ──
# WEBDAV_URL=
# WEBDAV_USER=
# WEBDAV_PASS=

# ── Infrastructure (deployment only) ──
IMAGE_TAG=latest
# DOKPLOY_URL=                # Dokploy API endpoint
# DOKPLOY_AUTH_TOKEN=         # Dokploy API token
