# Image tag (set by CI, or use 'latest' for local)
IMAGE_TAG=latest

# Server
HOST=0.0.0.0
PORT=8000

# OAuth (passwords are bcrypt hashes, generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
# )
AUTH_USERS=user1:$2b$12$placeholder
AUTH_SECRET_KEY=change-me-to-random-secret
AUTH_ISSUER=https://mcps.shen.iorlas.net

# Jackett
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=your-jackett-api-key

# TMDB
TMDB_API_KEY=your-tmdb-api-key

# Transmission
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_PATH=/transmission/rpc
TRANSMISSION_USER=
TRANSMISSION_PASS=
TRANSMISSION_SSL=false
