[
  {
    "name": "search_torrents",
    "description": "Search torrents (TSV). Fields: title, size, seeders, leechers, indexer",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "query": {
          "type": "string"
        },
        "alt_queries": {
          "default": null,
          "description": "Alternative queries (OR, deduped)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "search_type": {
          "default": "search",
          "enum": [
            "search",
            "movie",
            "tvsearch"
          ],
          "type": "string"
        },
        "year": {
          "default": null,
          "type": "integer"
        },
        "season": {
          "default": null,
          "type": "integer"
        },
        "episode": {
          "default": null,
          "type": "integer"
        },
        "categories": {
          "default": null,
          "description": "Category IDs (2000=Movies, 5000=TV)",
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "filter_expr": {
          "default": null,
          "description": "CEL filter. Examples: seeders > 10, size > 1000000000",
          "type": "string"
        },
        "search": {
          "default": null,
          "description": "Fuzzy text search across all fields (handles Cyrillic, transliteration)",
          "type": "string"
        },
        "fields": {
          "default": null,
          "description": "Fields (id auto-incl.)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "sort_by": {
          "default": null,
          "description": "Sort field, - prefix for desc",
          "type": "string"
        },
        "limit": {
          "default": 50,
          "type": "integer"
        },
        "offset": {
          "default": 0,
          "type": "integer"
        }
      },
      "required": [
        "query"
      ],
      "type": "object"
    }
  },
  {
    "name": "get_torrent",
    "description": "Get torrent details by ID. Resolves magnet link if not already available.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "torrent_id": {
          "description": "Torrent ID (jkt_xxxxxxxx)",
          "type": "string"
        }
      },
      "required": [
        "torrent_id"
      ],
      "type": "object"
    }
  }
]
