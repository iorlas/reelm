  {
    "name": "list_torrents",
    "description": "List torrents (TSV). No filter = all.\nFields: name, status, progress, eta, total_size, error_string, download_speed, file_count.\nCRITICAL: downloaded/completed = progress==`100` ONLY.\nNEVER use status for downloaded. status=='downloading' = ACTIVELY in-progress.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "filter_expr": {
          "default": null,
          "description": "CEL filter. Examples: progress == 100, status == 'downloading', id == 42",
          "type": "string"
        },
        "search": {
          "default": null,
          "description": "Fuzzy text search across all fields (handles Cyrillic, transliteration)",
          "type": "string"
        },
        "fields": {
          "default": null,
          "description": "Columns (id auto-incl.). Recommended: name,total_size. Drop columns implied by filter (e.g. progress if progress==100)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "sort_by": {
          "default": null,
          "description": "Sort field, - prefix for desc",
          "type": "string"
        },
        "limit": {
          "default": 50,
          "type": "integer"
        },
        "offset": {
          "default": 0,
          "type": "integer"
        }
      },
      "type": "object"
    }
  },
  {
    "name": "add_torrent",
    "description": "Add torrent by magnet link. ALWAYS use magneturl from get_torrent \u2014 it's more reliable than download URLs.\nIf download URL fails with 'expired', search again for fresh results.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "url": {
          "description": "Magnet link (strongly preferred). Get magneturl from get_torrent. Fallback: download URL.",
          "type": "string"
        },
        "category": {
          "default": null,
          "description": "Download subdirectory: tv, movies, music, other. Default: root download dir.",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    }
  },
